# External APIs
SERPER_API_KEY=your_serper_api_key_here
LLM_API_KEY=your_anthropic_or_openai_key_here

# Infrastructure (local dev; Docker Compose overrides these per service)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
REDIS_URL=redis://localhost:6379
POSTGRES_DSN=postgresql://pricescount:pricescount@localhost:5432/pricescount?sslmode=disable

# Service ports
DISCOVERY_PORT=8081
SCHEDULER_PORT=8082
EXTRACTOR_PORT=8083
NOTIFIER_PORT=8084
